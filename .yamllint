# Configuration yamllint du projet (make lint).
# Le style existant du dépôt utilise des commentaires longs en français ;
# on garde les règles par défaut mais on assouplit la longueur de ligne.
extends: default

rules:
  line-length:
    max: 150
  document-start: disable
  truthy:
    check-keys: false
  braces:
    max-spaces-inside: 1
