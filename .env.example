# Paramètres NON secrets du projet — copiez ce fichier en .env et remplissez VOS valeurs.
# .env est ignoré par git (voir .gitignore) : ne le committez jamais.
# Aucun mot de passe / token ne doit figurer ici : en CI, tout passe par GitHub Secrets.

# Votre nom d'utilisateur (ou organisation) GitHub.
GITHUB_USERNAME=<GITHUB_USERNAME>

# Votre fork, tel qu'affiché dans l'URL github.com/<user>/<repo>
GITHUB_REPOSITORY=<GITHUB_USERNAME>/supply-chain-security-project

# Nom de l'image applicative (ne changez que si vous renommez l'app).
IMAGE_NAME=scs-demo-app

# Tag local utilisé pendant le développement (labs 0-2).
# Le déploiement final se fait TOUJOURS par digest, jamais par ce tag mutable.
IMAGE_TAG=0.1.0

# Identité exigée par les policies Kyverno en mode keyless (Lab 5 / policies 03-04).
# Doit correspondre exactement au workflow + à la branche qui a produit l'image.
# Le workflow tourne sur main ET sur features/** (voir .github/workflows/supply-chain.yml) :
# si vous testez une image buildée depuis une feature branch, changez la fin en
# @refs/heads/features/ma-branche.
COSIGN_IDENTITY=https://github.com/<GITHUB_USERNAME>/supply-chain-security-project/.github/workflows/supply-chain.yml@refs/heads/main

# Émetteur OIDC Sigstore utilisé par GitHub Actions (ne pas modifier).
COSIGN_ISSUER=https://token.actions.githubusercontent.com

# Nom du cluster kind local.
KIND_CLUSTER_NAME=scs

# Namespace Kubernetes dédié à l'application.
APP_NAMESPACE=app
